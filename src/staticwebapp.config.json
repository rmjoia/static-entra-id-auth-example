{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "routes": [
    {
      "route": "/report.html",
      "allowedRoles": ["boardmember"]
    },
    {
      "route": "/strategy.html",
      "allowedRoles": ["boardmember"]
    },
    {
      "route": "/.auth/login/github",
      "statusCode": 404
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=.referrer",
      "statusCode": 302
    },
    "403": {
      "rewrite": "/403.html"
    }
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/*.{css,js,png,jpg,jpeg,gif,svg,ico,woff,woff2}"]
  }
}
